# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# OpenSea Sniper Config
# Format: ["0xPRIV_KEY_1", "0xPRIV_KEY_2"]
PRIVATE_KEYS=["0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"]
RPC_URL=https://mainnet.base.org
# The slug of the drop on OpenSea (e.g., "my-awesome-drop")
DROP_SLUG=example-drop-slug
# The contract address of the NFT
NFT_CONTRACT=0x0000000000000000000000000000000000000000
# Chain ID (e.g., 8453 for Base, 1 for Ethereum)
CHAIN_ID=8453
# Chain name (e.g., "base", "ethereum")
CHAIN_NAME=base
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
